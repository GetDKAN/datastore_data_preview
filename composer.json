{
  "name": "getdkan/datastore_data_preview",
  "description": "Paginated, sortable HTML table previews of DKAN datastore data.",
  "type": "drupal-module",
  "license": "GPL-2.0-or-later",
  "require": {
    "drupal/core": "^10.2 || ^11"
  },
  "suggest": {
    "getdkan/dkan": "Required for DatabaseDataSource and ResourceIdResolver functionality"
  },
  "require-dev": {
    "phpunit/phpunit": "^9 || ^10",
    "getdkan/mock-chain": "^1"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\datastore_data_preview\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Drupal\\Tests\\datastore_data_preview\\": "tests/src/"
    }
  },
  "config": {
    "allow-plugins": {
      "drupal/core-composer-scaffold": false
    }
  }
}
